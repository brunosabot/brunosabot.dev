{
  "name": "brunosabot.dev",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "lint:css": "stylelint --fix components/**/*.css styles/**/*.css",
    "lint:format": "prettier --write \"**/*.{css,js,jsx,json,md,ts,tsx}\"",
    "lint:ts": "eslint --fix \"components/**/*.tsx\" \"lib/**/*.ts\" \"app/**/*.{ts,tsx}\"",
    "lint": "eslint",
    "postbuild": "next-sitemap",
    "start": "next start -p 8080",
    "preinstall": "npx only-allow pnpm"
  },
  "pnpm": {
    "overrides": {
      "csstype": "3.2.3"
    },
    "onlyBuiltDependencies": [
      "@vercel/speed-insights",
      "sharp",
      "unrs-resolver"
    ]
  },
  "dependencies": {
    "@next/eslint-plugin-next": "^16.2.2",
    "@notionhq/client": "^5.16.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "eslint-plugin-perfectionist": "^5.8.0",
    "fuse.js": "^7.2.0",
    "lucide-react": "^1.7.0",
    "marked": "^17.0.5",
    "nanoid": "^5.1.7",
    "next": "16.2.2",
    "notion-to-md": "^3.1.9",
    "prismjs": "^1.30.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "reading-time": "^1.5.0",
    "sha.js": "^2.4.12",
    "sharp": "^0.34.5",
    "typescript": "6.0.2",
    "typescript-eslint": "^8.58.0",
    "ulid": "^3.0.2",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "@types/prismjs": "^1.26.6",
    "@types/react": "19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/sha.js": "^2.4.4",
    "eslint": "10.1.0",
    "eslint-config-next": "16.2.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "next-sitemap": "^4.2.3",
    "prettier": "^3.8.1",
    "stylelint": "^17.6.0",
    "stylelint-config-css-modules": "^4.6.0",
    "stylelint-config-recommended": "^18.0.0",
    "stylelint-order": "^8.1.1",
    "stylelint-prettier": "^5.0.3"
  },
  "lint-staged": {
    "*.css": [
      "prettier --write",
      "stylelint --fix"
    ],
    "*.{js,jsx}": [
      "eslint --ext .js,.ts,.tsx",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
